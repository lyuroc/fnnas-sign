#!/bin/bash
ERR_LOG="${TRIM_TEMP_LOGFILE:-/tmp/fnnas-install.log}"
echo "=== 飞牛论坛打卡 - 环境检查 ===" > "$ERR_LOG"
if ! command -v python3 &>/dev/null; then
    echo "[安装] 安装 python3..." >> "$ERR_LOG"
    apt-get update -qq 2>/dev/null
    apt-get install -y -qq python3 2>&1 >> "$ERR_LOG"
    if ! command -v python3 &>/dev/null; then
        echo "❌ 安装 python3 失败" > "$ERR_LOG"
        exit 1
    fi
fi
echo "[OK] python3: $(python3 --version)" >> "$ERR_LOG"
echo "[OK] 零外部依赖，Python 标准库已包含全部所需模块" >> "$ERR_LOG"
echo "🎉 环境就绪，开始安装..." >> "$ERR_LOG"
exit 0
